# Jennah Worker Configuration Template
# Copy this file to .env and fill in your values

# Batch Provider Configuration
BATCH_PROVIDER=gcp
PROJECT_ID=labs-169405 # or GCP_PROJECT or PROJECT_ID
REGION=asia-northeast1              # or REGION

# Database Configuration (Cloud Spanner)
DB_PROVIDER=spanner
DB_PROJECT_ID=your-gcp-project-id
DB_INSTANCE=your-spanner-instance
DB_DATABASE=your-database-name

# Server Configuration
WORKER_PORT=8081



